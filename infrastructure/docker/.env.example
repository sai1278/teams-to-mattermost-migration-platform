# Compose project metadata
COMPOSE_PROJECT_NAME=teams-mattermost-migration

# Container versions
POSTGRES_IMAGE_TAG=15-alpine@sha256:d16682b1464731be7547844093c4e0f06f5223e786b4ee9c049ee5cf2da0175b
MATTERMOST_IMAGE_TAG=9.5-alpine@sha256:060d4bca0d32ec06f7a6b8a8b136fb5672df99385fb93c3c726d11019c72e273
PROMETHEUS_IMAGE_TAG=v2.45.0@sha256:df66c6b3b55a820875c850257e84cbaf8997a48d8a7c29373950cf98a8813bc3
GRAFANA_IMAGE_TAG=10.0.3@sha256:b1d8f8a846c4f826359df3ad871891b97ad89495fc9f63567761019623259
LOKI_IMAGE_TAG=2.9.0@sha256:27d14d3f3f503d410f924fb6b9e598dc96a58f2780e9df7950c05877f2fb4864
PROMTAIL_IMAGE_TAG=2.9.0@sha256:49c065fde69d3513a0058b76dfb37c040d99ef8eb7741d4c20755b7a151b75c8
CADVISOR_IMAGE_TAG=v0.47.0@sha256:23c6803a114407b469e3556094b8eb2c1e194af2438b4d89694ec17eb66114eb1d
POSTGRES_EXPORTER_IMAGE_TAG=v0.12.0@sha256:23c6803a114407b469e3556094b8eb2c1e194af2438b4d89694ec17eb66114eb1d
PUSHGATEWAY_IMAGE_TAG=v1.8.0@sha256:8859cd68e1c6b5d911b6ffdbb94cb27f711c11029c788

# Host bindings
MATTERMOST_PORT=8065
POSTGRES_PORT=5432
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
CADVISOR_PORT=8080
POSTGRES_EXPORTER_PORT=9187
PUSHGATEWAY_PORT=9091

# Local database
POSTGRES_DB=mattermost
POSTGRES_USER=mmuser
POSTGRES_PASSWORD=change-me-in-local-env

# Mattermost application settings
MM_SERVICESETTINGS_SITEURL=http://localhost:8065
MM_SERVICESETTINGS_LISTENADDRESS=:8065
MATTERMOST_LOG_LEVEL=INFO
MATTERMOST_PLUGIN_ENABLE=false
MATTERMOST_METRICS_ENABLE=true

# Observability credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Local migration workflow defaults
ANONYMIZE_EXPORTS=false
AUTO_APPROVE_IMPORT=false
LOCAL_IMPORT_INPUT=tests/fixtures/sample-teams-export.json
LOCAL_IMPORT_OUTPUT=artifacts/imports/sample-import.jsonl
TMMP_BATCH_SIZE=500
TMMP_LOG_LEVEL=INFO
TMMP_METRICS_OUTPUT_PATH=artifacts/metrics/parser.prom
TMMP_METRICS_PUSHGATEWAY_URL=http://localhost:9091

# Reserved for future distributed execution
REDIS_URL=redis://redis:6379/0
OBJECT_STORAGE_BUCKET=teams-mattermost-imports
OBJECT_STORAGE_ENDPOINT=https://storage.example.internal
